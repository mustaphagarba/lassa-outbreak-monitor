   "source": [
    "def validate_business_rules(df: pd.DataFrame) -> Dict[str, List[str]]:\n",
    "    \"\"\"Validate epidemiological business rules\"\"\"\n",
    "    validation_issues: Dict[str, List[str]] = {}\n",
    "    \n",
    "    # Rule 1: Confirmed cases should not exceed total cases\n",
    "    if 'confirmed_cases' in df.columns and 'total_cases' in df.columns:\n",
    "        invalid_confirmed: pd.Series = (\n",
    "            df['confirmed_cases'].notna() & \n",
    "            df['total_cases'].notna() & \n",
    "            (df['confirmed_cases'] > df['total_cases'])\n",
    "        )\n",
    "        \n",
    "        if invalid_confirmed.any():\n",
    "            count: int = invalid_confirmed.sum()\n",
    "            validation_issues['confirmed_vs_total'] = [\n",
    "                f\"{count} records where confirmed cases > total cases\"\n",
    "            ]\n",
    "    \n",
    "    # Rule 2: Deaths should not exceed confirmed cases\n",
    "    if 'deaths' in df.columns and 'confirmed_cases' in df.columns:\n",
    "        invalid_deaths: pd.Series = (\n",
    "            df['deaths'].notna() & \n",
    "            df['confirmed_cases'].notna() & \n",
    "            (df['deaths'] > df['confirmed_cases'])\n",
    "        )\n",
    "        \n",
    "        if invalid_deaths.any():\n",
    "            count: int = invalid_deaths.sum()\n",
    "            validation_issues['deaths_vs_confirmed'] = [\n",
    "                f\"{count} records where deaths > confirmed cases\"\n",
    "            ]\n",
    "    \n",
    "    # Rule 3: CFR should match calculated CFR (within tolerance)\n",
    "    if all(col in df.columns for col in ['case_fatality_rate', 'deaths', 'confirmed_cases']):\n",
    "        valid_data: pd.DataFrame = df[\n",
    "            df['case_fatality_rate'].notna() & \n",
    "            df['deaths'].notna() & \n",
    "            df['confirmed_cases'].notna() & \n",
    "            (df['confirmed_cases'] > 0)\n",
    "        ].copy()\n",
    "        \n",
    "        if len(valid_data) > 0:\n",
    "            calculated_cfr: pd.Series = (valid_data['deaths'] / valid_data['confirmed_cases']) * 100\n",
    "            cfr_diff: pd.Series = np.abs(valid_data['case_fatality_rate'] - calculated_cfr)\n",
    "            \n",
    "            # Allow 5% tolerance\n",
    "            tolerance_exceeded: pd.Series = cfr_diff > 5.0\n",
    "            \n",
    "            if tolerance_exceeded.any():\n",
    "                count: int = tolerance_exceeded.sum()\n",
    "                validation_issues['cfr_calculation'] = [\n",
    "                    f\"{count} records where reported CFR differs from calculated by >5%\"\n",
    "                ]\n",
    "    \n",
    "    # Rule 4: Check for unrealistic weekly increases\n",
    "    if 'new_cases_week' in df.columns:\n",
    "        valid_new_cases: pd.Series = df['new_cases_week'].dropna()\n",
    "        \n",
    "        if len(valid_new_cases) > 0:\n",
    "            # Flag weekly increases > 1000% of median\n",
    "            median_cases: float = valid_new_cases.median()\n",
    "            if median_cases > 0:\n",
    "                extreme_increases: pd.Series = valid_new_cases > (median_cases * 10)\n",
    "                \n",
    "                if extreme_increases.any():\n",
    "                    count: int = extreme_increases.sum()\n",
    "                    validation_issues['extreme_increases'] = [\n",
    "                        f\"{count} records with weekly cases >10x median ({median_cases:.0f})\"\n",
    "                    ]\n",
    "    \n",
    "    return validation_issues\n",
    "\n",
    "# Run business rule validation\n",
    "business_issues = validate_business_rules(df_cleaned)\n",
    "\n",
    "print(\"🔍 Business Rule Validation:\")\n",
    "if business_issues:\n",
    "    for rule, issues in business_issues.items():\n",
    "        print(f\"  ⚠️ {rule}:\")\n",
    "        for issue in issues:\n",
    "            print(f\"    - {issue}\")\nelse:\n",
    "    print(\"  ✅ All business rules passed!\")"
   ]
  },
  {
   "cell_type": "code",
