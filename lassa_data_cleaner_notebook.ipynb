   "source": [
    "## 3. Data Cleaning {#cleaning}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_numeric_fields(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"Clean and standardize numeric fields with proper type hints\"\"\"\n",
    "    df_clean: pd.DataFrame = df.copy()\n",
    "    \n",
    "    # Clean case numbers\n",
    "    case_columns: List[str] = ['total_cases', 'confirmed_cases', 'deaths', 'new_cases_week', 'new_deaths_week']\n",
    "    \n",
    "    for col in case_columns:\n",
    "        if col in df_clean.columns:\n",
    "            # Convert to numeric, handling errors\n",
    "            df_clean[col] = pd.to_numeric(df_clean[col], errors='coerce')\n",
    "            \n",
    "            # Set negative values to NaN\n",
    "            negative_count: int = (df_clean[col] < 0).sum()\n",
    "            if negative_count > 0:\n",
    "                print(f\"⚠️ Found {negative_count} negative values in {col}, setting to NaN\")\n",
    "                df_clean.loc[df_clean[col] < 0, col] = np.nan\n",
    "            \n",
    "            # Cap extreme outliers (beyond 99.9 percentile)\n",
    "            if df_clean[col].notna().any():\n",
    "                cap_value: float = df_clean[col].quantile(0.999)\n",
    "                outliers_before: int = (df_clean[col] > cap_value).sum()\n",
    "                \n",
    "                if outliers_before > 0:\n",
    "                    df_clean.loc[df_clean[col] > cap_value, col] = cap_value\n",
    "                    print(f\"🎯 Capped {outliers_before} outliers in {col} to {cap_value}\")\n",
    "    \n",
    "    # Clean rates and percentages\n",
    "    if 'case_fatality_rate' in df_clean.columns:\n",
    "        df_clean['case_fatality_rate'] = pd.to_numeric(df_clean['case_fatality_rate'], errors='coerce')\n",
    "        \n",
    "        # Cap CFR at 100% and set negative to NaN\n",
    "        high_cfr: int = (df_clean['case_fatality_rate'] > 100).sum()\n",
    "        if high_cfr > 0:\n",
    "            print(f\"🎯 Capped {high_cfr} CFR values above 100%\")\n",
    "            df_clean.loc[df_clean['case_fatality_rate'] > 100, 'case_fatality_rate'] = 100\n",
    "            \n",
    "        negative_cfr: int = (df_clean['case_fatality_rate'] < 0).sum()\n",
    "        if negative_cfr > 0:\n",
    "            print(f\"⚠️ Set {negative_cfr} negative CFR values to NaN\")\n",
    "            df_clean.loc[df_clean['case_fatality_rate'] < 0, 'case_fatality_rate'] = np.nan\n",
    "    \n",
    "    # Clean geographic counts\n",
    "    geo_columns: List[str] = ['affected_states', 'affected_lgas']\n",
    "    for col in geo_columns:\n",
    "        if col in df_clean.columns:\n",
    "            df_clean[col] = pd.to_numeric(df_clean[col], errors='coerce')\n",
    "            negative_geo: int = (df_clean[col] < 0).sum()\n",
    "            if negative_geo > 0:\n",
    "                print(f\"⚠️ Set {negative_geo} negative values in {col} to NaN\")\n",
    "                df_clean.loc[df_clean[col] < 0, col] = np.nan\n",
    "    \n",
    "    return df_clean\n",
    "\n",
    "# Apply cleaning\n",
    "df_cleaned = clean_numeric_fields(df_raw)\n",
    "print(\"\\n✅ Numeric field cleaning completed\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def standardize_dates(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"Standardize and validate date fields\"\"\"\n",
    "    df_dated: pd.DataFrame = df.copy()\n",
    "    \n",
    "    # Create proper epidemiological dates\n",
    "    def calculate_epi_date(row: pd.Series) -> Optional[str]:\n",
    "        \"\"\"Calculate epidemiological week date\"\"\"\n",
    "        try:\n",
    "            year: int = int(row['year'])\n",
    "            week: int = int(row['week'])\n",
    "            \n",
    "            # Use ISO week date (Monday as first day)\n",
    "            # Week 1 is the first week with Thursday in the new year\n",
    "            jan_4: datetime = datetime(year, 1, 4)\n",
    "            week_1_monday: datetime = jan_4 - timedelta(days=jan_4.weekday())\n",
    "            epi_date: datetime = week_1_monday + timedelta(weeks=week-1)\n",
    "            \n",
    "            return epi_date.strftime('%Y-%m-%d')\n",
    "        \n",
    "        except (ValueError, TypeError):\n",
    "            return None\n",
    "    \n",
    "    # Apply date calculation\n",
    "    df_dated['epi_date'] = df_dated.apply(calculate_epi_date, axis=1)\n",
    "    df_dated['epi_date'] = pd.to_datetime(df_dated['epi_date'], errors='coerce')\n",
    "    \n",
    "    # Add additional date components\n",
    "    df_dated['month'] = df_dated['epi_date'].dt.month\n",
    "    df_dated['quarter'] = df_dated['epi_date'].dt.quarter\n",
    "    df_dated['year_month'] = df_dated['epi_date'].dt.to_period('M')\n",
    "    \n",
    "    valid_dates: int = df_dated['epi_date'].notna().sum()\n",
    "    print(f\"📅 Created {valid_dates} valid epidemiological dates\")\n",
    "    \n",
    "    return df_dated\n",
    "\n",
    "# Apply date standardization\n",
    "df_cleaned = standardize_dates(df_cleaned)\n",
    "print(\"✅ Date standardization completed\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Missing Value Imputation {#imputation}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def impute_missing_values(df: pd.DataFrame) -> Tuple[pd.DataFrame, Dict[str, str]]:\n",
    "    \"\"\"Intelligent missing value imputation with tracking\"\"\"\n",
    "    df_imputed: pd.DataFrame = df.copy()\n",
    "    imputation_log: Dict[str, str] = {}\n",
    "    \n",
    "    # Sort by date for time-series imputation\n",
    "    df_imputed = df_imputed.sort_values(['year', 'week'])\n",
    "    \n",
    "    # Impute confirmed cases from total cases\n",
    "    if 'confirmed_cases' in df_imputed.columns and 'total_cases' in df_imputed.columns:\n",
    "        missing_confirmed: pd.Series = df_imputed['confirmed_cases'].isnull()\n",
    "        has_total: pd.Series = df_imputed['total_cases'].notna()\n",
    "        \n",
    "        # Use 70% of total cases as default confirmed cases (historical average)\n",
    "        impute_mask: pd.Series = missing_confirmed & has_total\n",
    "        impute_count: int = impute_mask.sum()\n",
    "        \n",
    "        if impute_count > 0:\n",
    "            df_imputed.loc[impute_mask, 'confirmed_cases'] = (\n",
    "                df_imputed.loc[impute_mask, 'total_cases'] * 0.7\n",
    "            ).round().astype('Int64')\n",
    "            imputation_log['confirmed_cases'] = f\"Imputed {impute_count} values using 70% of total_cases\"\n",
    "    \n",
    "    # Calculate CFR where missing but have cases and deaths\n",
    "    if all(col in df_imputed.columns for col in ['case_fatality_rate', 'deaths', 'confirmed_cases']):\n",
    "        missing_cfr: pd.Series = df_imputed['case_fatality_rate'].isnull()\n",
    "        has_cases_deaths: pd.Series = (\n",
    "            df_imputed['confirmed_cases'].notna() & \n",
    "            df_imputed['deaths'].notna() & \n",
    "            (df_imputed['confirmed_cases'] > 0)\n",
    "        )\n",
    "        \n",
    "        calculate_cfr_mask: pd.Series = missing_cfr & has_cases_deaths\n",
    "        cfr_count: int = calculate_cfr_mask.sum()\n",
    "        \n",
    "        if cfr_count > 0:\n",
    "            df_imputed.loc[calculate_cfr_mask, 'case_fatality_rate'] = (\n",
    "                (df_imputed.loc[calculate_cfr_mask, 'deaths'] / \n",
    "                 df_imputed.loc[calculate_cfr_mask, 'confirmed_cases']) * 100\n",
    "            ).round(2)\n",
    "            imputation_log['case_fatality_rate'] = f\"Calculated {cfr_count} CFR values from deaths/cases\"\n",
    "    \n",
    "    # Forward fill for affected states/LGAs (assumes persistence)\n",
    "    for col in ['affected_states', 'affected_lgas']:\n",
    "        if col in df_imputed.columns:\n",
    "            before_count: int = df_imputed[col].isnull().sum()\n",
    "            df_imputed[col] = df_imputed[col].fillna(method='ffill')\n",
    "            after_count: int = df_imputed[col].isnull().sum()\n",
    "            filled: int = before_count - after_count\n",
    "            \n",
    "            if filled > 0:\n",
    "                imputation_log[col] = f\"Forward filled {filled} values\"\n",
    "    \n",
    "    # Rolling median for weekly new cases/deaths\n",
    "    for col in ['new_cases_week', 'new_deaths_week']:\n",
    "        if col in df_imputed.columns:\n",
    "            before_count: int = df_imputed[col].isnull().sum()\n",
    "            \n",
    "            # Use 3-week rolling median\n",
    "            rolling_median: pd.Series = df_imputed[col].rolling(window=3, center=True).median()\n",
    "            df_imputed[col] = df_imputed[col].fillna(rolling_median)\n",
    "            \n",
    "            after_count: int = df_imputed[col].isnull().sum()\n",
    "            filled: int = before_count - after_count\n",
    "            \n",
    "            if filled > 0:\n",
    "                imputation_log[col] = f\"Filled {filled} values with 3-week rolling median\"\n",
    "    \n",
    "    return df_imputed, imputation_log\n",
    "\n",
    "# Apply imputation\n",
    "df_cleaned, imputation_log = impute_missing_values(df_cleaned)\n",
    "\n",
    "print(\"🔄 Missing Value Imputation Results:\")\n",
    "for field, method in imputation_log.items():\n",
    "    print(f\"  • {field}: {method}\")\n",
    "\n",
    "if not imputation_log:\n",
    "    print(\"  • No imputation needed - data is complete!\")"
   ]
  },
  {
   "cell_type": "markdown",
