   "source": [
    "## 5. Outlier Detection & Treatment {#outliers}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def detect_and_treat_outliers(df: pd.DataFrame, z_threshold: float = 3.0) -> Tuple[pd.DataFrame, Dict[str, int]]:\n",
    "    \"\"\"Detect and treat outliers using Z-score method\"\"\"\n",
    "    df_treated: pd.DataFrame = df.copy()\n",
    "    outlier_log: Dict[str, int] = {}\n",
    "    \n",
    "    # Columns to check for outliers\n",
    "    outlier_columns: List[str] = ['total_cases', 'confirmed_cases', 'deaths', 'new_cases_week', 'new_deaths_week']\n",
    "    \n",
    "    for col in outlier_columns:\n",
    "        if col not in df_treated.columns:\n",
    "            continue\n",
    "            \n",
    "        series: pd.Series = df_treated[col].dropna()\n",
    "        \n",
    "        if len(series) < 10:  # Need minimum data points\n",
    "            continue\n",
    "            \n",
    "        # Calculate Z-scores\n",
    "        mean_val: float = series.mean()\n",
    "        std_val: float = series.std()\n",
    "        \n",
    "        if std_val == 0:  # Avoid division by zero\n",
    "            continue\n",
    "            \n",
    "        z_scores: pd.Series = np.abs((series - mean_val) / std_val)\n",
    "        outliers: pd.Series = z_scores > z_threshold\n",
    "        outlier_count: int = outliers.sum()\n",
    "        \n",
    "        if outlier_count > 0:\n",
    "            # Cap outliers at the threshold value\n",
    "            upper_bound: float = mean_val + (z_threshold * std_val)\n",
    "            lower_bound: float = mean_val - (z_threshold * std_val)\n",
    "            \n",
    "            # Apply bounds\n",
    "            outlier_indices: pd.Index = series[outliers].index\n",
    "            for idx in outlier_indices:\n",
    "                if df_treated.loc[idx, col] > upper_bound:\n",
    "                    df_treated.loc[idx, col] = upper_bound\n",
    "                elif df_treated.loc[idx, col] < lower_bound:\n",
    "                    df_treated.loc[idx, col] = max(0, lower_bound)  # Don't go below 0\n",
    "            \n",
    "            outlier_log[col] = outlier_count\n",
    "    \n",
    "    return df_treated, outlier_log\n",
    "\n",
    "# Apply outlier treatment\n",
    "df_cleaned, outlier_log = detect_and_treat_outliers(df_cleaned)\n",
    "\n",
    "print(\"🎯 Outlier Treatment Results:\")\n",
    "for field, count in outlier_log.items():\n",
    "    print(f\"  • {field}: Treated {count} outliers\")\n",
    "\n",
    "if not outlier_log:\n",
    "    print(\"  • No outliers detected above Z-score threshold of 3.0\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},