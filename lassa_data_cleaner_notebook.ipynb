   "source": [
    "def export_cleaned_data(df: pd.DataFrame, data_dir: Path) -> Dict[str, str]:\n",
    "    \"\"\"Export cleaned data in multiple formats\"\"\"\n",
    "    export_files: Dict[str, str] = {}\n",
    "    \n",
    "    # Main cleaned dataset\n",
    "    main_file: Path = data_dir / \"cleaned\" / \"lassa_fever_clean.csv\"\n",
    "    df.to_csv(main_file, index=False)\n",
    "    export_files['main'] = str(main_file)\n",
    "    \n",
    "    # Time series data (for analysis)\n",
    "    if 'epi_date' in df.columns:\n",
    "        ts_data: pd.DataFrame = df[[\n",
    "            'epi_date', 'year', 'week', 'total_cases', 'confirmed_cases', \n",
    "            'deaths', 'case_fatality_rate', 'new_cases_week', 'new_deaths_week'\n",
    "        ]].copy()\n",
    "        \n",
    "        ts_data = ts_data.sort_values('epi_date')\n",
    "        ts_file: Path = data_dir / \"cleaned\" / \"lassa_fever_timeseries.csv\"\n",
    "        ts_data.to_csv(ts_file, index=False)\n",
    "        export_files['timeseries'] = str(ts_file)\n",
    "    \n",
    "    # Geographic data (for mapping)\n",
    "    geo_cols: List[str] = ['year', 'week', 'affected_states', 'affected_lgas', 'total_cases']\n",
    "    available_geo_cols: List[str] = [col for col in geo_cols if col in df.columns]\n",
    "    \n",
    "    if len(available_geo_cols) > 2:\n",
    "        geo_data: pd.DataFrame = df[available_geo_cols].dropna()\n",
    "        if len(geo_data) > 0:\n",
    "            geo_file: Path = data_dir / \"cleaned\" / \"lassa_fever_geographic.csv\"\n",
    "            geo_data.to_csv(geo_file, index=False)\n",
    "            export_files['geographic'] = str(geo_file)\n",
    "    \n",
    "    # Summary statistics\n",
    "    summary_stats: pd.DataFrame = df.describe(include='all')\n",
    "    summary_file: Path = data_dir / \"cleaned\" / \"data_summary_stats.csv\"\n",
    "    summary_stats.to_csv(summary_file)\n",
    "    export_files['summary'] = str(summary_file)\n",
    "    \n",
    "    return export_files\n",
    "\n",
    "# Export cleaned data\n",
    "exported_files = export_cleaned_data(df_cleaned, data_dir)\n",
    "\n",
    "print(\"📁 Exported Clean Data Files:\")\n",
    "for file_type, file_path in exported_files.items():\n",
    "    print(f\"  • {file_type.title()}: {file_path}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
