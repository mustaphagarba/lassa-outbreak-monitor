    "# Define data quality classes\n",
    "class DataQuality(Enum):\n",
    "    \"\"\"Data quality levels\"\"\"\n",
    "    EXCELLENT = \"excellent\"\n",
    "    GOOD = \"good\"\n",
    "    FAIR = \"fair\"\n",
    "    POOR = \"poor\"\n",
    "\n",
    "@dataclass\n",
    "class ValidationResult:\n",
    "    \"\"\"Results from data validation\"\"\"\n",
    "    field_name: str\n",
    "    total_records: int\n",
    "    missing_count: int\n",
    "    missing_percentage: float\n",
    "    outlier_count: int\n",
    "    quality_score: DataQuality\n",
    "    issues: List[str]"
   ]
