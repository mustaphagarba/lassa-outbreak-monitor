   "source": [
    "# Load scraped data\n",
    "data_dir = Path(\"data\")\n",
    "processed_dir = data_dir / \"processed\"\n",
    "cleaned_dir = data_dir / \"cleaned\"\n",
    "cleaned_dir.mkdir(exist_ok=True)\n",
    "\n",
    "# Load the main dataset\n",
    "try:\n",
    "    df_raw = pd.read_csv(processed_dir / \"lassa_fever_weekly_data.csv\")\n",
    "    print(f\"✅ Loaded {len(df_raw)} records from scraped data\")\n",
    "    print(f\"📊 Date range: {df_raw['year'].min()}-{df_raw['year'].max()}\")\n",
    "    print(f\"📋 Columns: {list(df_raw.columns)}\")\nexcept FileNotFoundError:\n",
    "    print(\"❌ Scraped data not found. Please run the scraper first.\")\n",
    "    df_raw = pd.DataFrame()\n",
    "\n",
    "df_raw.head()"
   ]
