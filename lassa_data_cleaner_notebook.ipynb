  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Quality Assessment {#quality}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define validation rules\n",
    "validation_rules: Dict[str, Dict[str, Union[int, float, bool]]] = {\n",
    "    'total_cases': {'min': 0, 'max': 50000, 'required': True},\n",
    "    'confirmed_cases': {'min': 0, 'max': 50000, 'required': True},\n",
    "    'deaths': {'min': 0, 'max': 10000, 'required': True},\n",
    "    'case_fatality_rate': {'min': 0.0, 'max': 100.0, 'required': False},\n",
    "    'affected_states': {'min': 1, 'max': 37, 'required': False},  # Nigeria has 36 states + FCT\n",
    "    'affected_lgas': {'min': 1, 'max': 800, 'required': False},   # Nigeria has ~774 LGAs\n",
    "    'new_cases_week': {'min': 0, 'max': 5000, 'required': False},\n",
    "    'new_deaths_week': {'min': 0, 'max': 1000, 'required': False},\n",
    "    'week': {'min': 1, 'max': 53, 'required': True},\n",
    "    'year': {'min': 2016, 'max': 2030, 'required': True}\n",
    "}\n",
    "\n",
    "print(\"📋 Validation rules defined for\", len(validation_rules), \"fields\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def validate_data_quality(df: pd.DataFrame, rules: Dict[str, Dict]) -> Dict[str, ValidationResult]:\n",
    "    \"\"\"Comprehensive data quality validation with type hints\"\"\"\n",
    "    validation_results: Dict[str, ValidationResult] = {}\n",
    "    \n",
    "    for field, field_rules in rules.items():\n",
    "        if field not in df.columns:\n",
    "            continue\n",
    "            \n",
    "        series: pd.Series = df[field]\n",
    "        total_records: int = len(series)\n",
    "        missing_count: int = series.isnull().sum()\n",
    "        missing_pct: float = (missing_count / total_records) * 100\n",
    "        \n",
    "        issues: List[str] = []\n",
    "        outlier_count: int = 0\n",
    "        \n",
    "        # Check missing values\n",
    "        if field_rules.get('required', False) and missing_count > 0:\n",
    "            issues.append(f\"{missing_count} missing values in required field\")\n",
    "        \n",
    "        # Check range violations for numeric fields\n",
    "        if series.dtype in ['int64', 'float64']:\n",
    "            valid_data: pd.Series = series.dropna()\n",
    "            \n",
    "            if len(valid_data) > 0:\n",
    "                min_val: Union[int, float] = field_rules.get('min', -np.inf)\n",
    "                max_val: Union[int, float] = field_rules.get('max', np.inf)\n",
    "                \n",
    "                below_min: int = (valid_data < min_val).sum()\n",
    "                above_max: int = (valid_data > max_val).sum()\n",
    "                outlier_count = below_min + above_max\n",
    "                \n",
    "                if below_min > 0:\n",
    "                    issues.append(f\"{below_min} values below minimum ({min_val})\")\n",
    "                if above_max > 0:\n",
    "                    issues.append(f\"{above_max} values above maximum ({max_val})\")\n",
    "        \n",
    "        # Determine quality score\n",
    "        if missing_pct == 0 and outlier_count == 0:\n",
    "            quality = DataQuality.EXCELLENT\n",
    "        elif missing_pct < 10 and outlier_count < 5:\n",
    "            quality = DataQuality.GOOD\n",
    "        elif missing_pct < 25 and outlier_count < 15:\n",
    "            quality = DataQuality.FAIR\n",
    "        else:\n",
    "            quality = DataQuality.POOR\n",
    "        \n",
    "        validation_results[field] = ValidationResult(\n",
    "            field_name=field,\n",
    "            total_records=total_records,\n",
    "            missing_count=missing_count,\n",
    "            missing_percentage=missing_pct,\n",
    "            outlier_count=outlier_count,\n",
    "            quality_score=quality,\n",
    "            issues=issues\n",
    "        )\n",
    "    \n",
    "    return validation_results\n",
    "\n",
    "# Run validation\n",
    "validation_results = validate_data_quality(df_raw, validation_rules)\n",
    "print(f\"✅ Validated {len(validation_results)} fields\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Display validation results\n",
    "validation_df = pd.DataFrame([\n",
    "    {\n",
    "        'Field': result.field_name,\n",
    "        'Quality': result.quality_score.value,\n",
    "        'Missing %': f\"{result.missing_percentage:.1f}%\",\n",
    "        'Outliers': result.outlier_count,\n",
    "        'Issues': ', '.join(result.issues) if result.issues else 'None'\n",
    "    }\n",
    "    for result in validation_results.values()\n",
    "])\n",
    "\n",
    "print(\"📊 Data Quality Assessment:\")\n",
    "display(validation_df)"
   ]
  },
  {
