   "source": [
    "# Create cleaning metadata\n",
    "cleaning_metadata: Dict[str, Union[str, int, Dict, List]] = {\n",
    "    'cleaning_date': datetime.now().isoformat(),\n",
    "    'original_records': len(df_raw),\n",
    "    'cleaned_records': len(df_cleaned),\n",
    "    'imputation_log': imputation_log,\n",
    "    'outliers_treated': outlier_log,\n",
    "    'business_rule_issues': business_issues,\n",
    "    'final_data_quality': {\n",
    "        field: {\n",
    "            'quality': result.quality_score.value,\n",
    "            'missing_percentage': result.missing_percentage,\n",
    "            'outlier_count': result.outlier_count\n",
    "        }\n",
    "        for field, result in final_validation.items()\n",
    "    },\n",
    "    'exported_files': list(exported_files.keys())\n",
    "}\n",
    "\n",
    "# Save metadata\n",
    "metadata_file: Path = data_dir / \"cleaned\" / \"cleaning_metadata.json\"\n",
    "with open(metadata_file, 'w') as f:\n",
    "    json.dump(cleaning_metadata, f, indent=2, default=str)\n",
    "\n",
    "print(f\"\\n📋 Cleaning metadata saved to: {metadata_file}\")"
