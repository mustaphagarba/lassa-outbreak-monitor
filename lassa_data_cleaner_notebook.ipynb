   "source": [
    "# Final data quality check\n",
    "final_validation = validate_data_quality(df_cleaned, validation_rules)\n",
    "\n",
    "print(\"📊 Final Data Quality Assessment:\")\n",
    "quality_summary: Dict[str, int] = {\n",
    "    'excellent': 0, 'good': 0, 'fair': 0, 'poor': 0\n",
    "}\n",
    "\n",
    "for result in final_validation.values():\n",
    "    quality_summary[result.quality_score.value] += 1\n",
    "\n",
    "print(f\"  ✨ Excellent: {quality_summary['excellent']} fields\")\n",
    "print(f\"  ✅ Good: {quality_summary['good']} fields\")\n",
    "print(f\"  ⚠️ Fair: {quality_summary['fair']} fields\")\n",
    "print(f\"  ❌ Poor: {quality_summary['poor']} fields\")\n",
    "\n",
    "# Show improvement\n",
    "original_missing: float = df_raw.isnull().sum().sum()\n",
    "cleaned_missing: float = df_cleaned.isnull().sum().sum()\n",
    "improvement: float = original_missing - cleaned_missing\n",
    "\n",
    "print(f\"\\n📈 Data Improvement:\")\n",
    "print(f\"  • Missing values reduced by {improvement} ({improvement/len(df_raw):.1f} per record)\")\nprint(f\"  • Data completeness: {((df_cleaned.notna().sum().sum()) / (len(df_cleaned) * len(df_cleaned.columns)) * 100):.1f}%\")"
   ]
